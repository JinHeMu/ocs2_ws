<mujoco model="tracer_jaka_zu5_scene">

  <compiler angle="radian"
            meshdir="/home/a/mujoco_sim/tracer_jaka_zu5/tracer_jaka_zu5_mjcf/tracer_jaka_zu5/meshes" />

  <!-- 引入机器人描述文件 -->
  <include file="tracer_jaka_zu5_robot.xml"/>

  <asset>
    <!-- 地板纹理 -->
    <texture name="groundplane" type="2d" builtin="checker" mark="edge"
             rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3" markrgb="0.8 0.8 0.8"
             width="300" height="300"/>
    <material name="groundplane" texture="groundplane" texrepeat="5 5"
              texuniform="true" reflectance="0.2"/>
  </asset>

  <worldbody>
    <light name="top" pos="0 0 3" dir="0 0 -1" diffuse="0.7 0.7 0.7" />

    <geom name="floor"
          type="plane"
          size="10 10 0.05"
          pos="0 0 0"
          material="groundplane"
          contype="1"
          conaffinity="1"
          condim="3"
          friction="2.0 0.01 0.001" />

    <!-- 四周墙体 -->
    <body name="wall_n" pos="0 3 0.5">
      <geom type="box" size="3 0.05 0.5"  contype="1" conaffinity="1"
            rgba="0.8 0.8 0.78 1"/>
    </body>

    <body name="wall_s" pos="0 -3 0.5">
      <geom type="box" size="3 0.05 0.5"  contype="1" conaffinity="1"
            rgba="0.8 0.8 0.78 1"/>
    </body>

    <body name="wall_e" pos="3 0 0.5">
      <geom type="box" size="0.05 3 0.5"  contype="1" conaffinity="1"
            rgba="0.8 0.8 0.78 1"/>
    </body>

    <body name="wall_w" pos="-3 0 0.5">
      <geom type="box" size="0.05 3 0.5"  contype="1" conaffinity="1"
            rgba="0.8 0.8 0.78 1"/>
    </body>

    <!-- ====================================================================== -->
    <!-- 静态障碍物: 与 task.info environmentCollision.obstacles 同步            -->
    <!-- 坐标系: MuJoCo world = map frame; task.info 使用 odom frame            -->
    <!-- map->odom TF: (-2, 0, 0), 即 x_map = x_odom - 2                       -->
    <!-- ====================================================================== -->

    <body name="box_1" pos="-0.70 -0.55 0.30">
      <geom type="box" size="0.15 0.15 0.30"
            contype="1" conaffinity="1" rgba="0.4 0.5 0.7 1"/>
    </body>

    <body name="box_2" pos="0.50 0.00 0.35">
      <geom type="box" size="0.15 0.15 0.35"
            contype="1" conaffinity="1" rgba="0.4 0.5 0.7 1"/>
    </body>

    <body name="cylinder_1" pos="-0.50 0.80 0.30">
      <geom type="cylinder" size="0.12 0.30"
            contype="1" conaffinity="1" rgba="0.6 0.4 0.2 1"/>
    </body>

    <body name="sphere_1" pos="0.00 1.00 0.25">
      <geom type="sphere" size="0.18"
            contype="1" conaffinity="1" rgba="0.7 0.3 0.3 1"/>
    </body>

    <body name="box_3" pos="-1.50 -1.20 0.20">
      <geom type="box" size="0.35 0.12 0.20"
            contype="1" conaffinity="1" rgba="0.5 0.45 0.35 1"/>
    </body>

    <body name="box_4" pos="0.00 -0.90 0.25">
      <geom type="box" size="0.20 0.20 0.25"
            contype="1" conaffinity="1" rgba="0.4 0.5 0.7 1"/>
    </body>

  </worldbody>

</mujoco>
