  <link name="tool0"/>

  <joint name="inertial_joint" type="fixed">
    <parent link="base_link" />
    <child link="inertial_link" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>

  <joint name="right_wheel" type="continuous">
    <parent link="base_link" />
    <child link="right_wheel_link" />
    <origin xyz="0 -0.17 -0.082" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit effort="50" velocity="10" />
    <dynamics damping="0.05" friction="0.1" />
  </joint>

  <joint name="left_wheel" type="continuous">
    <parent link="base_link" />
    <child link="left_wheel_link" />
    <origin xyz="0 0.17 -0.082" rpy="0 0 0" />
    <axis xyz="0 1 0" />
    <limit effort="50" velocity="10" />
    <dynamics damping="0.05" friction="0.1" />
  </joint>

  <joint name="fl_castor_wheel" type="fixed">
    <parent link="base_link" />
    <child link="fl_castor_link" />
    <origin xyz="0.18955 0.17 -0.0380886" rpy="-1.57 0 0" />
  </joint>

  <joint name="fl_wheel" type="fixed">
    <parent link="fl_castor_link" />
    <child link="fl_wheel_link" />
    <origin xyz="-0.0218084 0.0689114 0" rpy="0 0 0" />
  </joint>

