<?xml version="1.0" ?>
<!--
  Tracer + Jaka ZU5 移动机械臂 (ROS 2 Jazzy + Gazebo Harmonic 仿真版)
  改动要点 vs. 原 demo.urdf：
    1. left_wheel / right_wheel 由 fixed 改为 continuous（OCS2 wheel-based 模型 + diff_drive_controller 都需要）
    2. 删除 Gazebo Classic 的 libgazebo_ros_diff_drive / libgazebo_ros_control 插件
    3. 删除原 <transmission> 块（ros2_control 不再使用）
    4. 通过 xacro:include 加载 ros2_control 与 gz_ros2_control 配置
    5. 修正了原文件 Link_3 / Link_4 中 origin xyz 参数缺第三位导致 xacro 解析失败的小错误
-->
<robot name="tracer_jaka_zu5" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- xacro 参数：sim_mode 区分 Gazebo / 实机 -->
  <xacro:arg name="sim_mode" default="true"/>
  <xacro:arg name="prefix"   default=""/>

  <!-- 加载 ros2_control + gz_ros2_control 块 -->
  <xacro:include filename="$(find tracer_jaka_gazebo)/urdf/tracer_jaka.ros2_control.xacro"/>
  <xacro:include filename="$(find tracer_jaka_gazebo)/urdf/tracer_jaka.gazebo.xacro"/>

  <!-- ==================== 移动底盘部分 ==================== -->
  <link name="base_link">
    <visual>
      <origin rpy="1.57 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/tracer_description/meshes/tracer_base_link_no_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.02"/>
      <geometry>
        <box size="0.58 0.58 0.18"/>
      </geometry>
    </collision>
    <inertial>
      <!-- base_link 自身需要质量否则 Gazebo 会拒绝加载 -->
      <mass value="10.0"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/>
    </inertial>
  </link>

  <link name="inertial_link">
    <inertial>
      <mass value="132.3898489950015"/>
      <origin xyz="0.015 0.0231316650320557 0"/>
      <inertia ixx="0.185196122711036" ixy="4.30144213829512E-08" ixz="5.81037523686401E-08"
               iyy="0.364893736238929"  iyz="-0.000386720198091934" izz="0.223868521722778"/>
    </inertial>
  </link>
  <joint name="inertial_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child  link="inertial_link"/>
  </joint>

  <!-- =========== 驱动轮：CONTINUOUS（被 diff_drive_controller 控制） =========== -->
  <link name="right_wheel_link">
    <inertial>
      <mass value="6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/tracer_description/meshes/tracer_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel" type="continuous">
    <parent link="base_link"/>
    <child  link="right_wheel_link"/>
    <origin rpy="0 0 0" xyz="0 -0.17 -0.082"/>
    <axis  xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.1"/>
    <limit effort="50" velocity="10"/>
  </joint>

  <link name="left_wheel_link">
    <inertial>
      <mass value="6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/tracer_description/meshes/tracer_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.065"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel" type="continuous">
    <parent link="base_link"/>
    <child  link="left_wheel_link"/>
    <origin rpy="0 0 0" xyz="0 0.17 -0.082"/>
    <axis  xyz="0 1 0"/>
    <dynamics damping="0.05" friction="0.1"/>
    <limit effort="50" velocity="10"/>
  </joint>

  <!-- =========== 万向轮支架 + 轮：保持 fixed，靠低摩擦让小球滑动 =========== -->
  <xacro:macro name="castor" params="name xyz">
    <link name="${name}_castor_link">
      <inertial>
        <mass value="0.5"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1e-3" ixy="0" ixz="0" iyy="1e-3" iyz="0" izz="1e-3"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tracer_jaka_gazebo/resources/tracer_description/meshes/castor_joint.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><cylinder length="0.04" radius="0.035"/></geometry>
      </collision>
    </link>
    <joint name="${name}_castor_wheel" type="fixed">
      <origin rpy="-1.57 0 0" xyz="${xyz}"/>
      <parent link="base_link"/>
      <child  link="${name}_castor_link"/>
    </joint>

    <link name="${name}_wheel_link">
      <inertial>
        <mass value="0.3"/>
        <origin xyz="0 0 0"/>
        <inertia ixx="1e-4" ixy="0" ixz="0" iyy="1e-4" iyz="0" izz="1e-4"/>
      </inertial>
      <visual>
        <geometry>
          <mesh filename="package://tracer_jaka_gazebo/resources/tracer_description/meshes/castor.dae"/>
        </geometry>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry><sphere radius="0.04"/></geometry>
      </collision>
    </link>
    <joint name="${name}_wheel" type="fixed">
      <parent link="${name}_castor_link"/>
      <child  link="${name}_wheel_link"/>
      <origin rpy="0 0 0" xyz="-0.0218084 0.067 0"/>
    </joint>
  </xacro:macro>

  <xacro:castor name="fl" xyz="0.18955  0.17 -0.0380886"/>
  <xacro:castor name="fr" xyz="0.18955 -0.17 -0.0380886"/>
  <xacro:castor name="rr" xyz="-0.18955 -0.17 -0.0380886"/>
  <xacro:castor name="rl" xyz="-0.18955  0.17 -0.0380886"/>

  <!-- ==================== 底盘上方铝型材（4 根） ==================== -->
  <xacro:macro name="aluminium_pillar" params="name xyz">
    <link name="${name}">
      <inertial>
        <origin rpy="0 0 0" xyz="0 0 0.1"/>
        <mass value="0.252739239169835"/>
        <inertia ixx="0.000880444836748547" ixy="0" ixz="0"
                 iyy="0.000884007661098085" iyz="0" izz="7.95242367143988E-05"/>
      </inertial>
      <visual>
        <origin rpy="0 0 0" xyz="0 0 0"/>
        <geometry>
          <mesh filename="package://tracer_jaka_gazebo/resources/aluminium/meshes/aluminium_base_link.STL"/>
        </geometry>
        <material name="white"><color rgba="0.898 0.917 0.929 1"/></material>
      </visual>
      <collision>
        <origin rpy="0 0 0" xyz="0 0 0.1"/>
        <geometry><box size="0.025 0.025 0.20"/></geometry>
      </collision>
    </link>
    <joint name="joint_${name}" type="fixed">
      <origin rpy="0 0 1.57" xyz="${xyz}"/>
      <parent link="base_link"/>
      <child  link="${name}"/>
    </joint>
  </xacro:macro>
  <xacro:aluminium_pillar name="aluminium_base_link"   xyz="-0.142  0.115 0.016"/>
  <xacro:aluminium_pillar name="aluminium_2_base_link" xyz="-0.142 -0.115 0.016"/>
  <xacro:aluminium_pillar name="aluminium_3_base_link" xyz=" 0.145  0.115 0.016"/>
  <xacro:aluminium_pillar name="aluminium_4_base_link" xyz=" 0.145 -0.115 0.016"/>

  <!-- 机械臂安装平台 -->
  <link name="urbase_base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0821499280748119 0 -0.00250008544254768"/>
      <mass value="0.965960559010444"/>
      <inertia ixx="0.0122165277186615" ixy="0" ixz="0"
               iyy="0.0276040033352521" iyz="0" izz="0.0398165064505868"/>
    </inertial>
    <visual>
      <origin rpy="0 0 -1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/second_base/meshes/urbase_base_link.STL"/>
      </geometry>
      <material name="plate_white"><color rgba="1 1 1 1"/></material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="-0.08 0 -0.0025"/>
      <geometry><box size="0.6 0.4 0.04"/></geometry>
    </collision>
  </link>
  <joint name="tracer_base" type="fixed">
    <origin rpy="0 0 1.57" xyz="0 0 0.218"/>
    <parent link="base_link"/>
    <child  link="urbase_base_link"/>
  </joint>

  <link name="base_footprint"/>
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child  link="base_link"/>
    <origin rpy="0 0 0" xyz="0 0 0.136"/>
  </joint>

  <!-- ==================== Jaka ZU5 机械臂 ==================== -->
  <link name="jaka_base_link"/>
  <joint name="base_to_jaka" type="fixed">
    <parent link="base_link"/>
    <child  link="jaka_base_link"/>
    <origin rpy="-0.02 0 0" xyz="0 0 0.221"/>
  </joint>

  <link name="Link_0">
    <inertial>
      <origin rpy="0 0 0" xyz="0.00096371 0 0.019555"/>
      <mass value="1.0392"/>
      <inertia ixx="0.0048763" ixy="0" ixz="0" iyy="0.0068003" iyz="0" izz="0.010618"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_0.STL"/>
      </geometry>
      <material name="silver"><color rgba="0.84706 0.84706 0.84706 1"/></material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.06"/>
      <geometry><cylinder length="0.2" radius="0.075"/></geometry>
    </collision>
  </link>
  <joint name="fixed_1" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="jaka_base_link"/>
    <child  link="Link_0"/>
  </joint>

  <link name="Link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.0033226 -0.001509"/>
      <mass value="1.5135"/>
      <inertia ixx="0.044302" ixy="0" ixz="0" iyy="0.043091" iyz="0" izz="0.030523"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_1.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0.072 0"/>
      <geometry><cylinder length="0.25" radius="0.075"/></geometry>
    </collision>
  </link>

  <link name="Link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0.215 0 -0.14315"/>
      <mass value="1.5847"/>
      <inertia ixx="0.10377" ixy="0" ixz="0" iyy="1.5964" iyz="0" izz="1.5689"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.14315"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_2.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.072"/>
      <geometry><cylinder length="0.25" radius="0.075"/></geometry>
    </collision>
    <collision>
      <origin rpy="0 1.5708 0" xyz="0.215 0 0.0"/>
      <geometry><cylinder length="0.40" radius="0.05"/></geometry>
    </collision>
    <collision>
      <origin rpy="0 0 0" xyz="0.43 0 0"/>
      <geometry><cylinder length="0.15" radius="0.06"/></geometry>
    </collision>
  </link>

  <link name="Link_3">
    <inertial>
      <origin rpy="0 0 0" xyz="0.19087 0 -0.010587"/>
      <mass value="1.8069"/>
      <inertia ixx="0.022066" ixy="0" ixz="0" iyy="0.41632" iyz="0" izz="0.41071"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_3.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.04"/>
      <geometry><cylinder length="0.15" radius="0.055"/></geometry>
    </collision>
    <collision>
      <origin rpy="0 1.5708 0" xyz="0.18 0 0.0"/>
      <geometry><cylinder length="0.32" radius="0.04"/></geometry>
    </collision>
    <!-- 修正：原 demo.urdf 此处 xyz 缺第三位 -->
    <collision>
      <origin rpy="0 0 0" xyz="0.3685 0 0"/>
      <geometry><cylinder length="0.15" radius="0.045"/></geometry>
    </collision>
  </link>

  <link name="Link_4">
    <inertial>
      <origin rpy="0 0 0" xyz="0 -0.0058004 0.0026717"/>
      <mass value="1.5525"/>
      <inertia ixx="0.0092564" ixy="0" ixz="0" iyy="0.0052251" iyz="0" izz="0.0089683"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_4.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 -0.05 0"/>
      <geometry><cylinder length="0.20" radius="0.045"/></geometry>
    </collision>
  </link>

  <link name="Link_5">
    <inertial>
      <origin rpy="0 0 0" xyz="0 -0.0028889 -0.0023424"/>
      <mass value="1.3339"/>
      <inertia ixx="0.012993" ixy="0" ixz="0" iyy="0.0058454" iyz="0" izz="0.0127"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_5.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry><cylinder length="0.12" radius="0.045"/></geometry>
    </collision>
  </link>

  <link name="Link_6">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 -0.021245"/>
      <mass value="1.4169"/>
      <inertia ixx="0.00071853" ixy="0" ixz="0" iyy="0.00072375" iyz="0" izz="0.0011337"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jaka_zu5_meshes/Link_6.STL"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.025"/>
      <geometry><cylinder length="0.05" radius="0.04"/></geometry>
    </collision>
  </link>

  <link name="Link_6_45"/>
  <joint name="fixed_2" type="fixed">
    <origin rpy="0 0 -0.7854" xyz="0 0 0"/>
    <parent link="Link_6"/>
    <child  link="Link_6_45"/>
  </joint>

  <!-- 6 个回转关节 -->
  <joint name="joint_1" type="revolute">
    <origin rpy="0 0 0" xyz="0 0 0.12015"/>
    <parent link="Link_0"/><child link="Link_1"/>
    <axis xyz="0 0 1"/>
    <limit effort="2000" lower="-6.28" upper="6.28" velocity="3.14"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>
  <joint name="joint_2" type="revolute">
    <origin rpy="1.5708 0 0" xyz="0 0.14315 0"/>
    <parent link="Link_1"/><child link="Link_2"/>
    <axis xyz="0 0 1"/>
    <limit effort="5000" lower="-1.48" upper="4.62" velocity="3.14"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>
  <joint name="joint_3" type="revolute">
    <origin rpy="0 0 0" xyz="0.43 0 0.14315"/>
    <parent link="Link_2"/><child link="Link_3"/>
    <axis xyz="0 0 1"/>
    <limit effort="5000" lower="-3.05" upper="3.05" velocity="3.14"/>
    <dynamics damping="1.0" friction="0.5"/>
  </joint>
  <joint name="joint_4" type="revolute">
    <origin rpy="0 0 0" xyz="0.3685 -1.185E-05 -0.114"/>
    <parent link="Link_3"/><child link="Link_4"/>
    <axis xyz="0 0 1"/>
    <limit effort="2000" lower="-1.48" upper="4.62" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>
  <joint name="joint_5" type="revolute">
    <origin rpy="1.5708 0 0" xyz="0 -0.1135 0"/>
    <parent link="Link_4"/><child link="Link_5"/>
    <axis xyz="0 0 1"/>
    <limit effort="3000" lower="-6.28" upper="6.28" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>
  <joint name="joint_6" type="revolute">
    <origin rpy="-1.5708 0 0" xyz="0 0.107 0"/>
    <parent link="Link_5"/><child link="Link_6"/>
    <axis xyz="0 0 1"/>
    <limit effort="1000" lower="-6.28" upper="6.28" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.3"/>
  </joint>

  <!-- ==================== 视觉相机 + 末端 ==================== -->
  <link name="jk_se_vi_200_link">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0 0.00519325476237179"/>
      <mass value="0.113976498368271"/>
      <inertia ixx="5.64946593588005E-05" ixy="0" ixz="0"
               iyy="5.49156738067512E-05" iyz="0" izz="8.64640542438198E-05"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 -0.0315"/>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/jk_se_vi_200/meshes/jk_se_vi_200_link.stl" scale="0.001 0.001 0.001"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.005"/>
      <geometry><box size="0.07 0.07 0.07"/></geometry>
    </collision>
  </link>
  <joint name="jk_se_vi_200_joint" type="fixed">
    <origin rpy="0 0 0.785398" xyz="0 0 0.0315"/>
    <parent link="Link_6_45"/>
    <child  link="jk_se_vi_200_link"/>
  </joint>

  <!-- 夹爪 base（其余指节作 fixed，不参与 OCS2 控制） -->
  <link name="gripper_base_link">
    <inertial>
      <mass value="0.83416"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.0013016" ixy="0" ixz="0" iyy="0.00049972" iyz="0" izz="0.001498"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="package://tracer_jaka_gazebo/resources/dh_robotics_ag95_description/meshes/visual/dh_base_link.STL" scale="0.001 0.001 0.001"/>
      </geometry>
      <material name="silver"/>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.05"/>
      <geometry><box size="0.075 0.045 0.10"/></geometry>
    </collision>
  </link>
  <joint name="gripper_base_joint" type="fixed">
    <parent link="jk_se_vi_200_link"/>
    <child  link="gripper_base_link"/>
    <origin rpy="0 0 -0.7853" xyz="0 0 0.005"/>
  </joint>

  <!-- TCP -->
  <link name="gripper_center_link"/>
  <joint name="gripper_center_joint" type="fixed">
    <origin rpy="0 0 -0.785398" xyz="0 0 0.225"/>
    <parent link="jk_se_vi_200_link"/>
    <child  link="gripper_center_link"/>
  </joint>

  <!-- ==================== ros2_control + Gazebo 插件 ==================== -->
  <xacro:tracer_jaka_ros2_control sim_mode="$(arg sim_mode)"/>
  <xacro:tracer_jaka_gazebo/>

</robot>
