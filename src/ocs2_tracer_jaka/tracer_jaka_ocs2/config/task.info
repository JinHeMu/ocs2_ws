; ============================================================================
; End-effector 目标跟踪 (全身轨迹模式下必须关闭)
; ============================================================================
endEffector
{
  activate         false

  muPosition       10.0
  muOrientation    5.0
}

finalEndEffector
{
  muPosition       10.0
  muOrientation    5.0
}

; ============================================================================
; 全身轨迹跟踪 cost (WholeBodyTrajectoryCost)
; ============================================================================
wholeBodyTracking
{
  activate   true

  ; [问题1] 终端权重缩放 5 -> 1.0, 避免末尾过度追逐横向位置
  finalWeightScale  1.0

  Q
  {
    base
    {
      (0,0)  2.0   ; x   [m]
      (1,1)  2.0   ; y   [m]
      (2,2)  0.5   ; yaw [rad]  [问题1] 0.5 -> 2.0, 优先对齐航向
    }
    arm
    {
      (0,0)  1.0   ; joint_1
      (1,1)  1.0   ; joint_2
      (2,2)  1.0   ; joint_3
      (3,3)  1.0   ; joint_4
      (4,4)  1.0   ; joint_5
      (5,5)  1.0   ; joint_6
    }
  }
}

