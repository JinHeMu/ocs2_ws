inputCost
{
  R
  {
    base
    {
      defaultManipulator               { }
      floatingArmManipulator           { }
      fullyActuatedFloatingArmManipulator
      {
        scaling 1e-2
        (0,0)  5.0
        (1,1)  5.0
        (2,2)  5.0
        (3,3)  5.0
        (4,4)  5.0
        (5,5)  5.0
