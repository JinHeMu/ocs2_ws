      {
        (0,0)  -0.1
        (1,0)  -0.1
        (2,0)  -0.1
        (3,0)  -0.3
        (4,0)  -0.3
        (5,0)  -0.3
      }
      wheelBasedMobileManipulator
      {
        (0,0)  -0.25
        (1,0)  -0.5
      }
    }
    arm
    {
      (0,0)  -2.0
      (1,0)  -2.0
      (2,0)  -2.0
      (3,0)  -2.0
      (4,0)  -2.0
      (5,0)  -2.0
    }
  }

  upperBound
  {
    base
    {
      defaultManipulator               { }
      floatingArmManipulator           { }
      fullyActuatedFloatingArmManipulator
      {
        (0,0)  2.0
        (1,0)  2.0
        (2,0)  2.0
        (3,0)  0.3
        (4,0)  0.3
        (5,0)  0.3
      }
      wheelBasedMobileManipulator
      {
        (0,0)  0.25
        (1,0)  0.5
      }
    }
    arm
    {
      (0,0)  2.0
      (1,0)  2.0
      (2,0)  2.0
      (3,0)  2.0
      (4,0)  2.0
      (5,0)  2.0
    }
  }
}