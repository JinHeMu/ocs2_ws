; ============================================================================
; End-effector 目标跟踪 (全身轨迹模式下必须关闭)
;
; 注意: 只把 muPosition / muOrientation 设成 0 是不够的!
; 只要 EndEffectorConstraint 还挂在 problem 上, 它就会去解析
; TargetTrajectories.stateTrajectory 的 head<3>() 和 tail<4>();
; 而全身轨迹的 state 是 9 维 [x, y, yaw, q1..q6],
; tail<4>() 取到的是 q3..q6, 被当成四元数使用 -> 语义完全错误。
; 所以这里用 activate 把 constraint 整个从 problem 里摘掉。
;
; 若要切回 EE 目标模式:
;   endEffector.activate      -> true  (并恢复 muPosition/muOrientation)
;   finalEndEffector 权重      -> 恢复
;   wholeBodyTracking.activate -> false
;   MRT 节点参数 use_whole_body_target -> false
; ============================================================================
endEffector
{
  activate         false

  muPosition       10.0
  muOrientation    5.0
}

finalEndEffector
{
  muPosition       10.0
  muOrientation    5.0
}

; ============================================================================
; 全身轨迹跟踪 cost (WholeBodyTrajectoryCost)
;
;   L(x,t) = 0.5 * (x - x_d(t))' Q (x - x_d(t)),  yaw 误差自动 wrap 到 [-pi, pi]
;   x     = [x, y, yaw, q1..q6]                    (stateDim = 9)
;   x_d(t) 来自 ROS topic mobile_manipulator_mpc_target 里的 TargetTrajectories,
;          由 whole_body_trajectory_target_node 发布, 经 RosReferenceManager 传入。
;
; 与旧版的区别: 不再从 task 文件读 waypoints, 轨迹完全在运行时由 ROS 提供。
; ============================================================================
wholeBodyTracking
{
  activate   true

  ; 终端 cost 的权重缩放 (相对中间时刻 Q)
  finalWeightScale  1e-1

  ; 状态偏差权重 (对角)
  Q
  {
    base
    {
      (0,0)  10.0   ; x   [m]
      (1,1)  10.0   ; y   [m]
      (2,2)   4.0   ; yaw [rad]
    }
    arm
    {
      (0,0)  2.0    ; joint_1
      (1,1)  2.0    ; joint_2
      (2,2)  2.0    ; joint_3
      (3,3)  2.0    ; joint_4
      (4,4)  2.0    ; joint_5
      (5,5)  2.0    ; joint_6
    }
  }
}

