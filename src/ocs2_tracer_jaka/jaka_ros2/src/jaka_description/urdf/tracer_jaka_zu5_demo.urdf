  <!-- 机械臂安装平台：用 box 替换 -->
  <link name="urbase_base_link">
    <inertial>
      <origin rpy="0 0 0" xyz="-0.0821499280748119 0 -0.00250008544254768"/>
      <mass value="0.965960559010444"/>
      <inertia ixx="0.0122165277186615" ixy="0" ixz="0" iyy="0.0276040033352521" iyz="0" izz="0.0398165064505868"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
