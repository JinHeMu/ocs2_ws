<?xml version="1.0" ?>
<!-- =================================================================================== -->
<!-- |    简化碰撞模型版本：将 mesh collision 替换为基本几何体（cylinder/box/sphere） | -->
<!-- |    用于 OCS2 self-collision 检测，可显著加速碰撞查询                          | -->
<!-- =================================================================================== -->
<robot name="tracer_jaka_zu5">

  <!-- ==================== 移动底盘部分 ==================== -->
  <!-- Base link：用 box 近似 Tracer 底盘外形 -->
  <link name="base_link">
    <visual>
      <origin rpy="1.57 0 1.57" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/tracer_base_link_no_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 -0.02"/>
      <geometry>
        <box size="0.58 0.58 0.18"/>
      </geometry>
    </collision>
  </link>

  <link name="inertial_link">
    <inertial>
      <mass value="132.3898489950015"/>
      <origin xyz="0.015 0.0231316650320557 0"/>
      <inertia ixx="0.185196122711036" ixy="4.30144213829512E-08" ixz="5.81037523686401E-08" iyy="0.364893736238929" iyz="-0.000386720198091934" izz="0.223868521722778"/>
    </inertial>
  </link>
  <joint name="inertial_joint" type="fixed">
    <origin rpy="0 0 0" xyz="0 0 0"/>
    <parent link="base_link"/>
    <child link="inertial_link"/>
  </joint>

  <!-- 驱动轮：简化为圆柱 -->
  <link name="right_wheel_link">
    <inertial>
      <mass value="6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/tracer_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.085"/>
      </geometry>
    </collision>
  </link>
  <joint name="right_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="right_wheel_link"/>
    <origin rpy="0 0 0" xyz="0 -0.17 -0.082"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <link name="left_wheel_link">
    <inertial>
      <mass value="6"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/tracer_wheel.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.08" radius="0.085"/>
      </geometry>
    </collision>
  </link>
  <joint name="left_wheel" type="fixed">
    <parent link="base_link"/>
    <child link="left_wheel_link"/>
    <origin rpy="3.14 0 0" xyz="0 0.17 -0.082"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <!-- 万向轮支架与轮子：简化为小圆柱/球 -->
  <link name="fl_castor_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor_joint.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="fl_castor_wheel" type="fixed">
    <origin rpy="-1.57 0 0" xyz="0.18955 0.17 -0.0380886"/>
    <parent link="base_link"/>
    <child link="fl_castor_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <link name="fr_castor_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor_joint.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="fr_castor_wheel" type="fixed">
    <origin rpy="-1.57 0 0" xyz="0.18955 -0.17 -0.0380886"/>
    <parent link="base_link"/>
    <child link="fr_castor_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <link name="rr_castor_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor_joint.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="rr_castor_wheel" type="fixed">
    <origin rpy="-1.57 0 0" xyz="-0.18955 -0.17 -0.0380886"/>
    <parent link="base_link"/>
    <child link="rr_castor_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <link name="rl_castor_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.7171" ixy="0" ixz="0" iyy="0.1361" iyz="0" izz="0.7171"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor_joint.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <cylinder length="0.04" radius="0.035"/>
      </geometry>
    </collision>
  </link>
  <joint name="rl_castor_wheel" type="fixed">
    <origin rpy="-1.57 0 0" xyz="-0.18955 0.17 -0.0380886"/>
    <parent link="base_link"/>
    <child link="rl_castor_link"/>
    <axis rpy="0 0 0" xyz="0 1 0"/>
  </joint>

  <!-- 万向轮：小球 -->
  <link name="fl_wheel_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.3131" ixy="0" ixz="0" iyy="0.3131" iyz="0" izz="0.1361"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="fl_wheel" type="fixed">
    <parent link="fl_castor_link"/>
    <child link="fl_wheel_link"/>
    <dynamics damping="0.0" friction="0.0"/>
    <origin rpy="0 0 0" xyz="-0.0218084 0.067 0"/>
    <axis rpy="0 0 0" xyz="0 0 1"/>
  </joint>

  <link name="fr_wheel_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.3131" ixy="0" ixz="0" iyy="0.3131" iyz="0" izz="0.1361"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="fr_wheel" type="fixed">
    <parent link="fr_castor_link"/>
    <child link="fr_wheel_link"/>
    <dynamics damping="0.0" friction="0.0"/>
    <origin rpy="0 0 0" xyz="-0.0218084 0.067 0"/>
    <axis rpy="0 0 0" xyz="0 0 1"/>
  </joint>

  <link name="rr_wheel_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.3131" ixy="0" ixz="0" iyy="0.3131" iyz="0" izz="0.1361"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="rr_wheel" type="fixed">
    <parent link="rr_castor_link"/>
    <child link="rr_wheel_link"/>
    <dynamics damping="0.0" friction="0.0"/>
    <origin rpy="0 0 0" xyz="-0.0218084 0.067 0"/>
    <axis rpy="0 0 0" xyz="0 0 1"/>
  </joint>

  <link name="rl_wheel_link">
    <inertial>
      <mass value="1"/>
      <origin xyz="0 0 0"/>
      <inertia ixx="0.3131" ixy="0" ixz="0" iyy="0.3131" iyz="0" izz="0.1361"/>
    </inertial>
    <visual>
      <geometry>
        <mesh filename="../meshes/tracer_description/meshes/castor.dae"/>
      </geometry>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <sphere radius="0.04"/>
      </geometry>
    </collision>
  </link>
  <joint name="rl_wheel" type="fixed">
    <parent link="rl_castor_link"/>
    <child link="rl_wheel_link"/>
    <dynamics damping="0.0" friction="0.0"/>
    <origin rpy="0 0 0" xyz="-0.0218084 0.067 0"/>
    <axis rpy="0 0 0" xyz="0 0 1"/>
  </joint>

  <!-- ==================== 传动 / Gazebo 控制（保持原样） ==================== -->
  <transmission name="right_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="right_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="right_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="left_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="left_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="left_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="fl_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="fl_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="fl_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="fr_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="fr_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="fr_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="rr_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="rr_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="rr_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="rl_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="rl_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="rl_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="fl_castor_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="fl_castor_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="fl_castor_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="fr_castor_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="fr_castor_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="fr_castor_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="rr_castor_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="rr_castor_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="rr_castor_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>
  <transmission name="rl_castor_wheel_trans" type="SimpleTransmission">
    <type>transmission_interface/SimpleTransmission</type>
    <actuator name="rl_castor_wheel_motor"><mechanicalReduction>1</mechanicalReduction></actuator>
    <joint name="rl_castor_wheel"><hardwareInterface>hardware_interface/VelocityJointInterface</hardwareInterface></joint>
  </transmission>

  <gazebo>
    <plugin filename="libgazebo_ros_control.so" name="gazebo_ros_control">
      <robotNamespace>/</robotNamespace>
    </plugin>
  </gazebo>
  <gazebo>
    <mu1 value="1.0"/>
    <mu2 value="0.9"/>
    <kp value="10000000.0"/>
    <kd value="1.0"/>
    <fdir1 value="1 0 0"/>
    <minDepth value="0.001"/>
    <maxContacts value="64"/>
  </gazebo>
  <gazebo>
    <plugin filename="libgazebo_ros_diff_drive.so" name="differential_drive_controller">
      <rosDebugLevel>Debug</rosDebugLevel>
      <robotNamespace>/</robotNamespace>
      <publishTf>1</publishTf>
      <alwaysOn>true</alwaysOn>
      <updateRate>30</updateRate>
      <legacyMode>true</legacyMode>
      <leftJoint>left_wheel</leftJoint>
      <rightJoint>right_wheel</rightJoint>
      <wheelSeparation>2</wheelSeparation>
      <wheelDiameter>0.32918</wheelDiameter>
      <broadcastTF>1</broadcastTF>
      <publishWheelTF>false</publishWheelTF>
      <publishWheelJointState>false</publishWheelJointState>
      <wheelTorque>30</wheelTorque>
      <wheelAcceleration>1.8</wheelAcceleration>
      <commandTopic>cmd_vel</commandTopic>
      <odometryFrame>odom</odometryFrame>
      <odometryTopic>odom</odometryTopic>
      <robotBaseFrame>base_link</robotBaseFrame>
    </plugin>
  </gazebo>

