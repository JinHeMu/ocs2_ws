  </link>

  <!-- ==================== Jaka ZU5 机械臂部分（核心简化） ==================== -->
  <link name="jaka_base_link"/>
  <link name="Link_6_45"/>

  <!-- Link_0：底座，圆柱替代 -->
  <link name="Link_0">
    <inertial>
      <origin rpy="0 0 0" xyz="0.00096371 0 0.019555"/>
      <mass value="4.0392"/>
      <inertia ixx="0.0048763" ixy="0" ixz="0" iyy="0.0068003" iyz="0" izz="0.010618"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/jaka_zu5_meshes/Link_0.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.84706 0.84706 0.84706 1"/>
      </material>
    </visual>
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.06"/>
      <geometry>
        <cylinder length="0.2" radius="0.075"/>
      </geometry>
    </collision>
  </link>

  <!-- Link_1：肩关节 -->
  <link name="Link_1">
    <inertial>
      <origin rpy="0 0 0" xyz="0 0.0033226 -0.001509"/>
      <mass value="15.135"/>
      <inertia ixx="0.044302" ixy="0" ixz="0" iyy="0.043091" iyz="0" izz="0.030523"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0"/>
      <geometry>
        <mesh filename="../meshes/jaka_zu5_meshes/Link_1.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.84706 0.84706 0.84706 1"/>
      </material>
    </visual>
    <!-- 肩关节壳体：沿 y 方向延伸到 joint_2 -->
    <collision>
      <origin rpy="1.5708 0 0" xyz="0 0.072 0"/>
      <geometry>
        <cylinder length="0.25" radius="0.075"/>
      </geometry>
    </collision>
  </link>

  <!-- Link_2：大臂（最关键，长 0.43m） -->
  <link name="Link_2">
    <inertial>
      <origin rpy="0 0 0" xyz="0.215 0 -0.14315"/>
      <mass value="45.847"/>
      <inertia ixx="0.10377" ixy="0" ixz="0" iyy="1.5964" iyz="0" izz="1.5689"/>
    </inertial>
    <visual>
      <origin rpy="0 0 0" xyz="0 0 0.14315"/>
      <geometry>
        <mesh filename="../meshes/jaka_zu5_meshes/Link_2.STL"/>
      </geometry>
      <material name="">
        <color rgba="0.84706 0.84706 0.84706 1"/>
      </material>
    </visual>
    <!-- 肩转关节壳体（位于 Link_2 原点） -->
    <collision>
      <origin rpy="0 0 0" xyz="0 0 0.072"/>
      <geometry>
        <cylinder length="0.25" radius="0.075"/>
      </geometry>
    </collision>
    <!-- 大臂主管：沿 x 方向，z=0.14315 高度 -->
    <collision>
      <origin rpy="0 1.5708 0" xyz="0.215 0 0.0"/>
      <geometry>
