<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="tracer_jaka_zu5">
    <xacro:arg name="initial_positions_file" default="initial_positions.yaml" />

    <!-- Import tracer_jaka_zu5 urdf file -->
    <xacro:include filename="$(find tracer_jaka_mujoco)/urdf/tracer_jaka_zu5.urdf" />

    <!-- Import control_xacro
    <xacro:include filename="tracer_jaka_zu5.ros2_control.xacro" /> -->


    <!-- <xacro:tracer_jaka_zu5_ros2_control name="FakeSystem" initial_positions_file="$(arg initial_positions_file)"/> -->

</robot>
